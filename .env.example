DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=google/gemma-2-9b-it

# Optional: company bootstrap CLI/API uses this when --dart-api-key or request.dart_api_key is omitted.
DART_API_KEY=

# Optional API protection.
APP_API_KEY=
APP_JWT_SECRET=
APP_JWT_ALGORITHM=HS256
APP_JWT_EXP_MINUTES=480

# Original document storage. local or s3/minio.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=storage
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION_NAME=ap-northeast-2

APP_ENV=local
