# AX Delivery Planner backend 환경변수 예시.
# 실제 실행 시에는 이 파일을 `.env`로 복사한 뒤 API key와 DB 접속 정보를 채운다.
# 비밀값이 들어가는 `.env`는 git에 올리지 않는다.

# PostgreSQL / pgvector 연결 정보. RAG chunk, 분석 결과, 문서 metadata가 저장된다.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Embedding과 OpenAI 계열 LLM 호출에 사용한다. 테스트/로컬 fallback만 볼 때는 비워둘 수 있다.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# RAG chunking 기본값. semantic strategy는 의미 유사도를 보고 chunk boundary를 잡는다.
RAG_CHUNK_STRATEGY=semantic
RAG_SEMANTIC_SIMILARITY_THRESHOLD=0.16
RAG_SEMANTIC_MIN_CHUNK_CHARS=360

# 로컬 vLLM endpoint. 기본 모델은 사용자의 로컬 `.env` 값으로 교체해서 쓴다.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=gemma-4-e4b-it

# Optional external LLM APIs for Supervisor model routing.
# vLLM remains the local/default path; GPT/Claude are selected only when enabled and keys exist.
ANTHROPIC_API_KEY=
MODEL_ROUTER_ENABLED=true
MODEL_ROUTER_ENABLE_VLLM=true
MODEL_ROUTER_ENABLE_OPENAI=true
MODEL_ROUTER_ENABLE_ANTHROPIC=true
MODEL_ROUTER_TARGET_SECONDS=45
MODEL_ROUTER_COST_SENSITIVITY=0.35
MODEL_ROUTER_QUALITY_FLOOR_MARGIN=0.12

# Supervisor always uses this upper-tier model when the provider is available.
SUPERVISOR_MODEL_PROVIDER=openai
SUPERVISOR_MODEL_NAME=gpt-5.6-sol
SUPERVISOR_LLM_ENABLED=true
SUPERVISOR_MINIMAL_HUMAN_APPROVAL=true
SUPERVISOR_LLM_TIMEOUT_SECONDS=45
SUPERVISOR_LLM_RETRY_COUNT=2
SUPERVISOR_LLM_RETRY_TIMEOUT_MULTIPLIER=1.8
AGENT_LLM_TIMEOUT_SECONDS=10
AGENT_LLM_RETRY_COUNT=1
AGENT_LLM_RETRY_TIMEOUT_MULTIPLIER=1.6

# Supervisor long-goal autonomy. The workflow runs extra loops by default, but
# only inside bounded loop/cost limits and only escalates truly risky decisions.
SUPERVISOR_AUTONOMY_ENABLED=true
SUPERVISOR_AUTONOMY_LEVEL=controlled_high
SUPERVISOR_AUTONOMOUS_MAX_STAGE_LOOPS=4
SUPERVISOR_AUTONOMOUS_EXTRA_LOOP_BUDGET=2
SUPERVISOR_AUTONOMOUS_COST_BUDGET_USD=1.5

# GPT candidates and estimated USD cost per 1M tokens.
OPENAI_HIGH_MODEL=gpt-5.6-sol
OPENAI_BALANCED_MODEL=gpt-5.6-terra
OPENAI_FAST_MODEL=gpt-5.6-luna
# Supervisor는 위 SUPERVISOR_MODEL_NAME을 고정 사용한다.
# 나머지 Agent/critic/report는 아래 추가 GPT 후보까지 함께 비교해,
# 요구 품질 하한을 넘으면 더 저렴한 모델을 우선 선택할 수 있다.
# 실제 계정에서 접근 가능한 GPT 모델명/가격으로 조정한다.
OPENAI_EXTRA_MODEL_PROFILES_JSON=[{"model":"gpt-4.1-mini","tier":"economy","quality_score":0.74,"speed_score":0.94,"context_window_tokens":1048576,"input_cost_per_million":0.40,"output_cost_per_million":1.60},{"model":"gpt-4.1-nano","tier":"nano","quality_score":0.67,"speed_score":0.97,"context_window_tokens":1048576,"input_cost_per_million":0.10,"output_cost_per_million":0.40}]
OPENAI_HIGH_INPUT_COST_PER_MILLION=5.00
OPENAI_HIGH_OUTPUT_COST_PER_MILLION=30.00
OPENAI_BALANCED_INPUT_COST_PER_MILLION=2.50
OPENAI_BALANCED_OUTPUT_COST_PER_MILLION=15.00
OPENAI_FAST_INPUT_COST_PER_MILLION=1.00
OPENAI_FAST_OUTPUT_COST_PER_MILLION=6.00

# Anthropic candidates and estimated USD cost per 1M tokens.
ANTHROPIC_HIGH_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_FAST_MODEL=claude-3-5-haiku-latest
ANTHROPIC_HIGH_INPUT_COST_PER_MILLION=3.00
ANTHROPIC_HIGH_OUTPUT_COST_PER_MILLION=15.00
ANTHROPIC_FAST_INPUT_COST_PER_MILLION=0.80
ANTHROPIC_FAST_OUTPUT_COST_PER_MILLION=4.00

# Local vLLM comparison values. Marginal API cost is usually zero, but quality/speed
# scores let the router compare local and paid models with one formula.
VLLM_INPUT_COST_PER_MILLION=0
VLLM_OUTPUT_COST_PER_MILLION=0
VLLM_QUALITY_SCORE=0.62
VLLM_SPEED_SCORE=0.72
VLLM_CONTEXT_WINDOW_TOKENS=8192

# Optional: company bootstrap CLI/API uses this when --dart-api-key or request.dart_api_key is omitted.
DART_API_KEY=

# Optional external public web discovery during replan. Disabled by default.
EXTERNAL_WEB_DISCOVERY_ENABLED=false
EXTERNAL_WEB_SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
EXTERNAL_WEB_MAX_RESULTS=3

# Expert Agent loop guard. Set false or run --disable-agent-extra-loop to force
# the old bounded handoff behavior.
AGENT_SUPERVISOR_MAX_TOOL_LOOPS=2
AGENT_SUPERVISOR_EXTRA_LOOP_ENABLED=true

# Replan guard. 0 disables replan; 1 allows one evidence refresh before Human Review.
AGENT_REPLAN_MAX_ATTEMPTS=1

# Optional API protection.
APP_API_KEY=
APP_JWT_SECRET=
APP_JWT_ALGORITHM=HS256
APP_JWT_EXP_MINUTES=480

# Original document storage. local or s3/minio.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=storage
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION_NAME=ap-northeast-2

# Agent tool isolation. direct for development, docker for command-style tool isolation.
AGENT_TOOL_SANDBOX_MODE=direct
AGENT_TOOL_SANDBOX_IMAGE=python:3.12-slim
AGENT_TOOL_SANDBOX_TIMEOUT_SECONDS=30
AGENT_TOOL_SANDBOX_NETWORK=none

# Graph node isolation. direct/subprocess/docker. subprocess isolates each graph node into a Python worker process.
GRAPH_NODE_EXECUTION_MODE=direct
GRAPH_NODE_WORKER_TIMEOUT_SECONDS=300
GRAPH_NODE_WORKER_IMAGE=ax-delivery-planner:latest

# Monitoring stack.
PROMETHEUS_SCRAPE_INTERVAL=15s
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# 실행 환경 이름. production에서는 보안 preflight가 더 엄격하게 동작한다.
APP_ENV=local
