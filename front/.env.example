# Vite frontend 환경변수 예시.
# `VITE_` prefix가 붙은 값만 browser bundle에서 접근 가능하다.

# FastAPI backend base URL. 로컬 실행 기본 port는 8001이다.
VITE_API_BASE_URL=http://127.0.0.1:8001

# 개발 편의를 위한 기본 인증 header 값. 운영에서는 실제 key/role 정책에 맞게 교체한다.
VITE_API_KEY=local-test-key
VITE_USER_ID=admin-user
VITE_USER_ROLE=admin
