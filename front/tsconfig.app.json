{
  "compilerOptions": {
    // React browser bundleмҡ© TypeScript compiler м„Өм •.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode: Viteк°Җ module bundlingмқ„ лӢҙлӢ№н•ҳлҜҖлЎң TypeScriptлҠ” type checkл§Ң мҲҳн–үн•ңлӢӨ. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting: unused codeмҷҖ switch fallthroughлҘј build лӢЁкі„м—җм„ң л№ лҘҙкІҢ мһЎлҠ”лӢӨ. */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
